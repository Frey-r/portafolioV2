---
import BaseLayout from '../layouts/BaseLayout.astro';

// Cálculo dinámico de años de experiencia desde 1 de mayo de 2022
const startDate = new Date('2022-05-01');
const now = new Date();
const yearsExp = Math.floor((now.getTime() - startDate.getTime()) / (1000 * 60 * 60 * 24 * 365.25));
---

<BaseLayout title="Eduardo Bachmann — Full Stack Developer">
  <section class="hero container">
    <div class="bento-grid">

      <!-- 1. Intro Tile (Double wide, Double tall) -->
      <div class="bento-cell bento-cell--intro observe-animate">
        <div class="bento-cell__overlay"></div>
        <div class="bento-cell__content">
          <span class="bento-cell__label">INTRODUCCIÓN</span>
          <h1 class="bento-cell__heading">
            Construyendo sistemas<br/>que piensan y escalan.
          </h1>
          <p class="bento-cell__text">
            Desarrollador backend con {yearsExp}+ años de experiencia construyendo microservicios, flujos agenticos con IA y arquitecturas cloud robustas.
          </p>
        </div>
        <div class="bento-cell__actions">
          <a href="/proyectos" class="btn btn-primary btn-lg">Ver Proyectos</a>
          <a href="https://github.com/Frey-r" target="_blank" rel="noopener noreferrer" class="btn btn-secondary btn-lg">Ver GitHub</a>
        </div>
      </div>

      <!-- 2. Featured Project Tile -->
      <a href="https://github.com/Frey-r/portafolio" target="_blank" rel="noopener noreferrer" class="bento-cell bento-cell--project observe-animate delay-1">
        <div class="bento-cell__badge">
          <span>Deployment Reciente</span>
        </div>
        <div class="bento-cell__image-wrap">
          <div class="bento-cell__project-content" id="last-push-content">
            <h3 id="last-push-repo">Cargando...</h3>
            <p id="last-push-message">Obteniendo último push...</p>
            <div class="last-push-meta">
              <span id="last-push-sha"></span>
              <span id="last-push-time"></span>
            </div>
          </div>
        </div>
      </a>

      <!-- 3. Status Tile -->
      <div class="bento-cell bento-cell--status observe-animate delay-2">
        <div class="bento-cell__status-gradient"></div>
        <div class="bento-cell__status-content">
          <div class="pulse-ring">
            <span class="pulse-dot"></span>
          </div>
          <h3>Disponible</h3>
          <p>Aceptando nuevos proyectos para Q3 2025</p>
        </div>
      </div>

      <!-- 4. Location Tile -->
      <div class="bento-cell bento-cell--location observe-animate delay-3">
        <span class="bento-cell__label">HORA LOCAL</span>
        <div class="bento-cell__location-content">
          <div class="bento-cell__time" id="local-time">--:--</div>
          <div class="bento-cell__place">
            <span class="material-symbols-outlined" style="font-size: 16px;">location_on</span>
            Chile
          </div>
        </div>
        <div class="bento-cell__location-blur"></div>
      </div>

      <!-- 5. Tech Stack Tile -->
      <div class="bento-cell bento-cell--stack observe-animate delay-4">
        <span class="bento-cell__label">STACK PRINCIPAL</span>
        <div class="stack-grid">
          <div class="stack-item">
            <div class="stack-item__icon">
              <span class="material-symbols-outlined">smart_toy</span>
            </div>
            <div>
              <h4>IA & Agentes</h4>
              <p>Flujos agenticos, multi-agentes y servidores MCP con Langchain y Langgraph.</p>
            </div>
          </div>
          <div class="stack-item">
            <div class="stack-item__icon">
              <span class="material-symbols-outlined">dns</span>
            </div>
            <div>
              <h4>Backend</h4>
              <p>Microservicios en Python (FastAPI) y Go (Gin) para producción.</p>
            </div>
          </div>
          <div class="stack-item">
            <div class="stack-item__icon">
              <span class="material-symbols-outlined">database</span>
            </div>
            <div>
              <h4>Base de Datos</h4>
              <p>SQL, NoSQL y bases vectoriales para búsqueda semántica.</p>
            </div>
          </div>
          <div class="stack-item">
            <div class="stack-item__icon">
              <span class="material-symbols-outlined">cloud</span>
            </div>
            <div>
              <h4>AWS & DevOps</h4>
              <p>EC2, Lambda, SQS, RDS. Contenedores y despliegues automáticos.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- 6. Toolkit Tile -->
      <div class="bento-cell bento-cell--toolkit observe-animate delay-5">
        <span class="bento-cell__label">TOOLKIT</span>
        <div class="chip-wrap">
          <span class="chip">Python</span>
          <span class="chip">FastAPI</span>
          <span class="chip">Go</span>
          <span class="chip">Langchain</span>
          <span class="chip">Langgraph</span>
          <span class="chip">MCPs</span>
          <span class="chip">Vue</span>
          <span class="chip">Astro</span>
          <span class="chip">AWS</span>
          <span class="chip">Docker</span>
        </div>
      </div>

    </div>
  </section>
</BaseLayout>

<script>
  function updateTime() {
    const el = document.getElementById('local-time');
    if (el) {
      const now = new Date();
      el.textContent = now.toLocaleTimeString('es-CL', {
        hour: '2-digit',
        minute: '2-digit',
        hour12: true,
        timeZone: 'America/Santiago'
      });
    }
  }
  updateTime();
  setInterval(updateTime, 30000);

  // Fetch last push from GitHub API
  async function fetchLastPush() {
    try {
      const res = await fetch('/api-portfolio/github/last-push');
      if (!res.ok) throw new Error('Failed to fetch');
      
      const data = await res.json();
      
      const repoEl = document.getElementById('last-push-repo');
      const messageEl = document.getElementById('last-push-message');
      const shaEl = document.getElementById('last-push-sha');
      const timeEl = document.getElementById('last-push-time');
      
      if (repoEl) repoEl.textContent = data.repo || 'portafolio';
      if (messageEl) messageEl.textContent = data.message || 'Sin mensaje';
      if (shaEl) shaEl.textContent = data.sha || '';
      if (timeEl) {
        const date = new Date(data.pushed_at);
        timeEl.textContent = date.toLocaleDateString('es-CL', {
          day: 'numeric',
          month: 'short',
          hour: '2-digit',
          minute: '2-digit'
        });
      }
    } catch (e) {
      console.error('Failed to fetch last push:', e);
      // Fallback
      const repoEl = document.getElementById('last-push-repo');
      const messageEl = document.getElementById('last-push-message');
      if (repoEl) repoEl.textContent = 'portafolio';
      if (messageEl) messageEl.textContent = 'No se pudo cargar el último push';
    }
  }
  
  fetchLastPush();
</script>

<style>
  .hero {
    padding-block: var(--space-xl) var(--space-4xl);
  }

  /* ── Bento Grid ── */
  .bento-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    grid-auto-rows: 280px;
  }

  @media (min-width: 768px) {
    .bento-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .bento-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* ── Cell Base ── */
  .bento-cell {
    border-radius: var(--radius-xl);
    position: relative;
    overflow: hidden;
    opacity: 0;
  }

  /* ── 1. Intro Cell ── */
  .bento-cell--intro {
    background-color: var(--color-surface-container-low);
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  @media (min-width: 768px) {
    .bento-cell--intro {
      grid-column: span 2;
      grid-row: span 2;
    }
  }

  .bento-cell__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-surface-container-low), var(--color-surface-container-highest));
    opacity: 0.5;
    pointer-events: none;
  }

  .bento-cell__content {
    position: relative;
    z-index: 1;
  }

  .bento-cell__label {
    display: block;
    font-size: 0.75rem;
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-on-surface-variant);
    margin-bottom: var(--space-md);
  }

  .bento-cell__heading {
    font-size: clamp(2.5rem, 5vw, 3.75rem);
    font-weight: var(--font-weight-extrabold);
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--color-primary);
    margin-bottom: var(--space-lg);
  }

  .bento-cell__text {
    font-size: 1.125rem;
    color: var(--color-on-surface-variant);
    line-height: 1.6;
    max-width: 28rem;
  }

  .bento-cell__actions {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-top: var(--space-xl);
    flex-wrap: wrap;
  }

  /* ── 2. Project Cell ── */
  .bento-cell--project {
    background-color: var(--color-surface-container-high);
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    cursor: pointer;
  }

  @media (min-width: 768px) {
    .bento-cell--project {
      grid-column: span 2;
    }
  }

  @media (min-width: 1024px) {
    .bento-cell--project {
      grid-column: span 2;
      grid-row: span 1;
    }
  }

  .bento-cell__badge {
    position: absolute;
    top: var(--space-xl);
    left: var(--space-xl);
    z-index: 20;
  }

  .bento-cell__badge span {
    background-color: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(12px);
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .bento-cell__image-wrap {
    width: 100%;
    height: 100%;
    border-radius: var(--radius-lg);
    overflow: hidden;
    position: relative;
  }

  .bento-cell__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-glacial);
  }

  .bento-cell--project:hover .bento-cell__image-wrap img {
    transform: scale(1.05);
  }

  .bento-cell__image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.6), transparent);
    display: flex;
    align-items: flex-end;
    padding: var(--space-lg);
  }

  .bento-cell__image-overlay h3 {
    font-size: 1.5rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-surface);
    margin-bottom: 0.25rem;
  }

  .bento-cell__image-overlay p {
    font-size: 0.875rem;
    color: var(--color-surface-dim);
  }

  /* ── Last Push Content ── */
  .bento-cell__project-content {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--space-lg);
    background: linear-gradient(135deg, var(--color-surface-container-high), var(--color-surface-container-highest));
    border-radius: var(--radius-lg);
  }

  .bento-cell__project-content h3 {
    font-size: 1.25rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-on-surface);
    margin-bottom: var(--space-sm);
  }

  .bento-cell__project-content p {
    font-size: 0.875rem;
    color: var(--color-on-surface-variant);
    line-height: 1.5;
    margin-bottom: var(--space-md);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .last-push-meta {
    display: flex;
    gap: var(--space-md);
    font-size: 0.75rem;
    color: var(--color-secondary);
  }

  .last-push-meta span:first-child {
    font-family: monospace;
    background-color: var(--color-surface-container-lowest);
    padding: 0.125rem 0.375rem;
    border-radius: var(--radius-sm);
  }

  /* ── 3. Status Cell ── */
  .bento-cell--status {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: var(--space-xl);
  }

  .bento-cell__status-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-container));
    pointer-events: none;
  }

  .bento-cell__status-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .bento-cell__status-content h3 {
    font-size: 1.25rem;
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--space-sm);
  }

  .bento-cell__status-content p {
    font-size: 0.875rem;
    opacity: 0.8;
  }

  .pulse-ring {
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background-color: rgba(204, 234, 214, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-md);
  }

  .pulse-dot {
    display: block;
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 50%;
    background-color: var(--color-primary-fixed);
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  /* ── 4. Location Cell ── */
  .bento-cell--location {
    background-color: var(--color-surface-container-low);
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .bento-cell__location-content {
    position: relative;
    z-index: 1;
    margin-top: auto;
  }

  .bento-cell__time {
    font-size: 2.5rem;
    font-weight: var(--font-weight-regular);
    letter-spacing: -0.04em;
    color: var(--color-primary);
    margin-bottom: 0.25rem;
  }

  .bento-cell__place {
    font-size: 0.875rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-on-surface-variant);
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .bento-cell__location-blur {
    position: absolute;
    bottom: -2.5rem;
    right: -2.5rem;
    width: 12rem;
    height: 12rem;
    background-color: var(--color-surface-container-highest);
    border-radius: 50%;
    opacity: 0.5;
    mix-blend-mode: multiply;
    filter: blur(2rem);
    pointer-events: none;
  }

  /* ── 5. Stack Cell ── */
  .bento-cell--stack {
    background-color: var(--color-surface-container-low);
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
  }

  @media (min-width: 768px) {
    .bento-cell--stack {
      grid-column: span 2;
      grid-row: span 2;
    }
  }

  .stack-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg) var(--space-xl);
    height: 100%;
    align-content: center;
  }

  @media (min-width: 480px) {
    .stack-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .stack-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-md);
  }

  .stack-item__icon {
    background-color: var(--color-surface-container-highest);
    padding: var(--space-sm);
    border-radius: var(--radius-lg);
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .stack-item h4 {
    font-weight: var(--font-weight-bold);
    color: var(--color-on-surface);
    margin-bottom: 0.25rem;
  }

  .stack-item p {
    font-size: 0.875rem;
    color: var(--color-on-surface-variant);
  }

  /* ── 6. Toolkit Cell ── */
  .bento-cell--toolkit {
    background-color: var(--color-surface-container-low);
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
  }

  @media (min-width: 1024px) {
    .bento-cell--toolkit {
      grid-column: span 2;
    }
  }

  .chip-wrap {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: auto;
  }
</style>
