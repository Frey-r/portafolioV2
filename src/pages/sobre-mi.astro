---
import BaseLayout from '../layouts/BaseLayout.astro';

// Cálculo dinámico de años de experiencia desde 1 de mayo de 2022
const startDate = new Date('2022-05-01');
const now = new Date();
const yearsExp = Math.floor((now.getTime() - startDate.getTime()) / (1000 * 60 * 60 * 24 * 365.25));
const currentYear = now.getFullYear();
---

<BaseLayout title="Sobre Mí — Eduardo Bachmann" description="Autodidacta. Impulsado por la curiosidad. Desarrollador full-stack enfocado en arquitectura escalable.">
  <div class="about container">

    <!-- Hero Section -->
    <section class="about-hero observe-animate">
      <div class="about-hero__text">
        <h1 class="about-hero__heading">
          Autodidacta.<br/>
          Impulsado por la curiosidad.
        </h1>
        <p class="about-hero__desc">
          Desarrollo desde los 16 años. Hoy, con {yearsExp}+ años de experiencia profesional, construyo microservicios backend, arquitecturas cloud en AWS y flujos agenticos con IA. Me nutro constantemente de documentación, cursos y colegas para aportar soluciones de valor en cada proyecto.
        </p>
        <div class="about-hero__cta">
          <a href="/contacto" class="btn btn-primary btn-lg">Hablemos</a>
        </div>
      </div>
      <div class="about-hero__image">
        <div class="about-hero__image-wrap">
          <img 
            src="/profile.webp" 
            alt="Fotografía de Eduardo Bachmann" 
            loading="lazy"
          />
          <div class="about-hero__image-fade"></div>
        </div>
      </div>
    </section>

    <!-- The Journey (Bento Grid) -->
    <section class="journey observe-animate delay-2">
      <div class="section-header">
        <h2 class="section-header__title">El Camino</h2>
        <p class="section-header__desc">De QA a backend IA. Una trayectoria enfocada en resolver problemas reales con código que se mantiene en producción.</p>
      </div>
      <div class="journey-grid">
        <!-- Philosophy -->
        <div class="journey-card journey-card--wide">
          <div class="journey-card__icon">
            <span class="material-symbols-outlined" style="font-size: 2rem;">menu_book</span>
          </div>
          <h3 class="journey-card__title">Aprendizaje Autodirigido</h3>
          <p class="journey-card__desc">
            Empecé a programar a los 16 años. Mi camino no fue tradicional: se forjó con documentación, cursos online y desarmando sistemas para entender cómo funcionan. Me adapto con facilidad a entornos cambiantes y disfruto tanto del trabajo en equipo como del desempeño autónomo.
          </p>
        </div>
        <!-- Milestones -->
        <div class="journey-card journey-card--milestones">
          <h3 class="journey-card__label">HITOS CLAVE</h3>
          <ul class="milestone-list">
            <li class="milestone-item">
              <span class="material-symbols-outlined milestone-icon">smart_toy</span>
              <div>
                <p class="milestone-item__title">Flujos Agenticos & MCPs</p>
                <p class="milestone-item__sub">Backend IA en ZeroQ</p>
              </div>
            </li>
            <li class="milestone-item">
              <span class="material-symbols-outlined milestone-icon">cloud</span>
              <div>
                <p class="milestone-item__title">Sistema de Reportería en AWS</p>
                <p class="milestone-item__sub">Lambda, SQS, RDS, EC2</p>
              </div>
            </li>
            <li class="milestone-item">
              <span class="material-symbols-outlined milestone-icon">verified</span>
              <div>
                <p class="milestone-item__title">Microservicios en Producción</p>
                <p class="milestone-item__sub">Firma digital y autenticación</p>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Experience Section -->
    <section class="experience observe-animate delay-3">
      <div class="section-header">
        <h2 class="section-header__title">Experiencia</h2>
        <p class="section-header__desc">Desarrollando soluciones en producción para sectores públicos, privados y startups tecnológicas.</p>
      </div>
      <div class="experience-list">
        <div class="experience-card">
          <div class="experience-card__header">
            <div>
              <h3 class="experience-card__title">Backend Developer IA</h3>
              <p class="experience-card__company">ZeroQ</p>
            </div>
            <span class="experience-card__period">2025 — Presente</span>
          </div>
          <p class="experience-card__desc">
            Creación de flujos de automatización agenticos, multi-agenticos y servidores MCP. Stack: Python (FastAPI, Pandas, SQLAlchemy, Langchain, Langgraph), Go (Gin), AWS y bases de datos relacionales, documentales y vectoriales.
          </p>
        </div>
        <div class="experience-card">
          <div class="experience-card__header">
            <div>
              <h3 class="experience-card__title">Desarrollador Backend</h3>
              <p class="experience-card__company">Idok</p>
            </div>
            <span class="experience-card__period">2022 — 2025</span>
          </div>
          <p class="experience-card__desc">
            Desarrollo y mantención de microservicios de autenticación y firma digital con Java 8 y Spring Boot para municipios, bancos y otras organizaciones. Implementé un sistema de reportería automatizada end-to-end en AWS (Lambda, SQS, RDS) para el área comercial. Inicié como QA automatizando pruebas con Python y Selenium.
          </p>
        </div>
        <div class="experience-card">
          <div class="experience-card__header">
            <div>
              <h3 class="experience-card__title">Desarrollador Frontend</h3>
              <p class="experience-card__company">Archfee</p>
            </div>
            <span class="experience-card__period">2023 — 2025</span>
          </div>
          <p class="experience-card__desc">
            Desarrollo del frontend de una plataforma para arquitectos con datos anónimos sobre costos y tiempos de construcción. Implementación en Ruby on Rails siguiendo lineamientos de diseño y creación del sitio informativo en WordPress/PHP. Lanzamiento planificado para Chile, Perú y Argentina.
          </p>
        </div>
      </div>
    </section>

    <!-- Core Philosophy -->
    <section class="philosophy observe-animate delay-4">
      <div class="section-header">
        <h2 class="section-header__title">Filosofía Core</h2>
        <p class="section-header__desc">Principios que guían mi código y mis decisiones de arquitectura.</p>
      </div>
      <div class="philosophy-grid">
        <div class="philosophy-card">
          <div class="philosophy-card__icon">
            <span class="material-symbols-outlined">architecture</span>
          </div>
          <h3 class="philosophy-card__title">Arquitectura Escalable</h3>
          <p class="philosophy-card__desc">Construyendo sistemas que anticipan el crecimiento sin sobre-ingeniería desde el día uno.</p>
        </div>
        <div class="philosophy-card">
          <div class="philosophy-card__icon">
            <span class="material-symbols-outlined">bug_report</span>
          </div>
          <h3 class="philosophy-card__title">Mantenibilidad</h3>
          <p class="philosophy-card__desc">Escribiendo código para el siguiente desarrollador. Documentación clara, tipado estricto y testing exhaustivo.</p>
        </div>
        <div class="philosophy-card">
          <div class="philosophy-card__icon">
            <span class="material-symbols-outlined">speed</span>
          </div>
          <h3 class="philosophy-card__title">Rendimiento</h3>
          <p class="philosophy-card__desc">Optimizando velocidad y eficiencia. Minimizando bundles y reduciendo queries a la base de datos.</p>
        </div>
        <div class="philosophy-card">
          <div class="philosophy-card__icon">
            <span class="material-symbols-outlined">design_services</span>
          </div>
          <h3 class="philosophy-card__title">UI / UX Focus</h3>
          <p class="philosophy-card__desc">Cerrando la brecha entre diseño e implementación técnica para una ejecución impecable.</p>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  .about {
    display: flex;
    flex-direction: column;
    gap: var(--space-4xl);
    padding-block: var(--space-3xl) var(--space-4xl);
  }

  /* ── Section Header ── */
  .section-header {
    margin-bottom: var(--space-2xl);
  }

  .section-header__title {
    font-size: 1.75rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-primary);
    margin-bottom: var(--space-md);
  }

  .section-header__desc {
    color: var(--color-on-surface-variant);
    max-width: 36rem;
    line-height: 1.6;
  }

  /* ── Hero Section ── */
  .about-hero {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
    align-items: center;
    opacity: 0;
  }

  @media (min-width: 768px) {
    .about-hero {
      flex-direction: row;
    }
  }

  .about-hero__text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .about-hero__heading {
    font-size: clamp(2.25rem, 4.5vw, 3.5rem);
    font-weight: var(--font-weight-extrabold);
    color: var(--color-primary);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .about-hero__desc {
    font-size: 1.125rem;
    color: var(--color-on-surface-variant);
    line-height: 1.6;
    max-width: 36rem;
  }

  .about-hero__cta {
    padding-top: var(--space-md);
  }

  .about-hero__image {
    flex: 1;
    width: 100%;
  }

  .about-hero__image-wrap {
    border-radius: var(--radius-xl);
    min-height: 400px;
    overflow: hidden;
    position: relative;
  }

  .about-hero__image-wrap img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-glacial);
  }

  .about-hero__image-wrap:hover img {
    transform: scale(1.05);
  }

  .about-hero__image-fade {
    position: absolute;
    inset: 0;
    opacity: 0.6;
  }

  /* ── Journey Grid ── */
  .journey {
    opacity: 0;
  }

  .journey-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  @media (min-width: 768px) {
    .journey-grid {
      grid-template-columns: 2fr 1fr;
    }
  }

  .journey-card {
    border-radius: var(--radius-xl);
    padding: var(--space-xl);
  }

  .journey-card--wide {
    background-color: var(--color-surface-container-low);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    transition: background-color var(--transition-normal);
  }

  .journey-card--wide:hover {
    background-color: var(--color-surface-container-high);
  }

  .journey-card__icon {
    color: var(--color-primary);
    opacity: 0.8;
    margin-bottom: var(--space-md);
  }

  .journey-card__title {
    font-size: 1.25rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-primary);
  }

  .journey-card__desc {
    color: var(--color-on-surface-variant);
    line-height: 1.6;
  }

  .journey-card--milestones {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
    border: 1px solid var(--color-primary-container);
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .journey-card__label {
    font-size: 0.875rem;
    font-weight: var(--font-weight-bold);
    color: rgba(255, 255, 255, 0.7);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .journey-card--milestones .milestone-icon {
    color: var(--color-primary-fixed);
  }

  .journey-card--milestones .milestone-item__title {
    color: var(--color-on-primary);
  }

  .journey-card--milestones .milestone-item__sub {
    color: rgba(255, 255, 255, 0.7);
  }

  .milestone-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .milestone-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .milestone-icon {
    color: var(--color-primary);
    font-size: 0.875rem;
    margin-top: 0.125rem;
  }

  .milestone-item__title {
    font-weight: var(--font-weight-bold);
    color: var(--color-on-surface);
  }

  .milestone-item__sub {
    font-size: 0.875rem;
    color: var(--color-on-surface-variant);
  }

  /* ── Experience ── */
  .experience {
    opacity: 0;
  }

  .experience-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .experience-card {
    background-color: var(--color-surface-container-low);
    border-radius: var(--radius-xl);
    padding: var(--space-xl);
    border-left: 4px solid transparent;
    transition: all var(--transition-normal);
  }

  .experience-card:hover {
    background-color: var(--color-surface-container-high);
    border-left-color: var(--color-primary);
  }

  .experience-card__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  @media (min-width: 768px) {
    .experience-card__header {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  .experience-card__title {
    font-size: 1.25rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-primary);
  }

  .experience-card__company {
    color: var(--color-on-surface-variant);
  }

  .experience-card__period {
    font-size: 0.875rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-on-surface-variant);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    background-color: var(--color-surface-container);
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-full);
    white-space: nowrap;
    width: fit-content;
  }

  .experience-card__desc {
    color: var(--color-on-surface-variant);
    line-height: 1.6;
    max-width: 48rem;
  }

  /* ── Philosophy ── */
  .philosophy {
    opacity: 0;
  }

  .philosophy-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  @media (min-width: 480px) {
    .philosophy-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .philosophy-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .philosophy-card {
    background-color: var(--color-primary);
    border-radius: var(--radius-xl);
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-md);
  }

  .philosophy-card__icon {
    padding: 0.75rem;
    border-radius: var(--radius-full);
    background-color: rgba(255, 255, 255, 0.1);
    color: var(--color-on-primary);
  }

  .philosophy-card__title {
    font-weight: var(--font-weight-bold);
    color: var(--color-on-primary);
  }

  .philosophy-card__desc {
    font-size: 0.875rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.8);
  }
</style>
